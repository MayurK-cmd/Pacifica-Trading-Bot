# ═══════════════════════════════════════════════════════════════════════════════
# PACIFICA-PILOT AGENT ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Production deployment: Agent connects to hosted backend for config & logging
# Frontend Dashboard: https://pacificia-trading-bot.vercel.app
# Backend API: https://pacificia-trading-bot.onrender.com
# ═══════════════════════════════════════════════════════════════════════════════

# ── BACKEND CONNECTION (REQUIRED) ──────────────────────────────────────────────
# Point to the hosted backend API for config sync and log streaming
BACKEND_URL=https://pacificia-trading-bot.onrender.com

# Shared secret for agent authentication (must match backend AGENT_API_SECRET)
AGENT_API_SECRET=aa78d2bdf36c0144bbf31ff05450d8d183f144b03a76a65e811e18af47d83480

# Your MongoDB User document _id (optional - agent fetches from backend)
# Get from MongoDB Atlas: pacifica-pilot > Users > _id
USER_ID=

# ── PACIFICA TRADING KEYS (REQUIRED FOR TRADING) ───────────────────────────────
# Pacifica testnet API endpoint
PACIFICA_BASE_URL=https://test-api.pacifica.fi/api/v1

# Pacifica WebSocket endpoint for real-time data
PACIFICA_WS_URL=wss://test-ws.pacifica.fi/ws

# Your main Pacifica wallet private key (base58 encoded)
# ⚠️ NEVER share this key - stays on YOUR machine only
PACIFICA_PRIVATE_KEY=<your_base58_private_key_from_pacifica_wallet>

# Agent wallet private key from test-app.pacifica.fi/apikey
# This is the "Secret" value shown when you create an API key
PACIFICA_AGENT_PRIVATE_KEY=<secret_from_test-app.pacifica.fi/apikey>

# Agent API public key from test-app.pacifica.fi/apikey
# This is the "API Key" value (public identifier)
PACIFICA_AGENT_PUBLIC_KEY=<api_key_from_test-app.pacifica.fi/apikey>

# ── AI SERVICE KEYS (REQUIRED FOR AI DECISIONS) ────────────────────────────────
# Google Gemini API key for trading decisions
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<your_gemini_api_key>

# Elfa AI API key for social sentiment analysis (optional)
# Get from: https://elfa.ai or Elfa x Pacifica hackathon dashboard
ELFA_API_KEY=<your_elfa_api_key>

# ── SAFETY OVERRIDE (CRITICAL) ────────────────────────────────────────────────
# DRY_RUN=true = Paper trading mode (simulated orders, real data)
# DRY_RUN=false = LIVE trading (real orders on Pacifica)
# ⚠️ Keep true for testing. Set false ONLY when ready for production.
DRY_RUN=true

# ── TRADING CONFIGURATION (SET VIA DASHBOARD, NOT ENV) ────────────────────────
# The following settings are now configured via the frontend dashboard:
# - TRADE_SYMBOLS (e.g., BTC,ETH,SOL)
# - LOOP_INTERVAL_SECONDS (default: 300)
# - MAX_POSITION_USDC (default: 50)
# - MIN_CONFIDENCE (default: 0.6)
# - STOP_LOSS_PCT (default: 3.0)
# - TAKE_PROFIT_PCT (default: 6.0)
# - RISK_LEVEL (conservative/balanced/aggressive)
#
# These env vars are deprecated and will be removed in future versions.
# Use the Config tab in the dashboard to set these values.

# ── DEPLOYMENT URLS REFERENCE ─────────────────────────────────────────────────
# Frontend Dashboard (Vercel):  https://pacificia-trading-bot.vercel.app
# Backend API (Render):         https://pacificia-trading-bot.onrender.com
#
# For local development, change BACKEND_URL to:
# - http://localhost:3001 (local backend)
# - Or use ngrok to expose local backend: https://your-tunnel.ngrok.io
